# ============================================================
# Footballeroo Web — Environment Variables
# ============================================================

# --- NextAuth ---
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=""
