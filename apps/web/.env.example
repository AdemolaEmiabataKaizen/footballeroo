# --- API URL (backend) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Database (for NextAuth PrismaAdapter) ---
DATABASE_URL="postgresql://footballeroo:footballeroo_dev@localhost:5432/footballeroo"
