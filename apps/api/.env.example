# ============================================================
# Footballeroo API — Environment Variables
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Database ---
DATABASE_URL="postgresql://footballeroo:footballeroo_dev@localhost:5432/footballeroo"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="your-jwt-secret-here"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# --- OpenAI ---
OPENAI_API_KEY=""

# --- Football Data ---
FOOTBALL_API_KEY=""
MOCK_FOOTBALL_DATA="true"

# --- AWS S3 (Image Storage) ---
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-2"
AWS_S3_BUCKET="footballeroo-images"

# --- Notifications ---
SENDGRID_API_KEY=""
ADMIN_EMAIL=""
