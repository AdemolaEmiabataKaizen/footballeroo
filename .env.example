# ============================================================
# Footballeroo — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL) ---
# Default matches docker-compose.yml credentials
DATABASE_URL="postgresql://footballeroo:footballeroo_dev@localhost:5432/footballeroo"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Authentication ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="your-jwt-secret-here"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- OpenAI (for Generation Engine, Taste Officer, Image Gen) ---
OPENAI_API_KEY=""

# --- Football Data ---
# https://www.football-data.org/ (free tier available)
FOOTBALL_API_KEY=""
# Set to "true" to use mocked fixture data instead of live API
MOCK_FOOTBALL_DATA="true"

# --- Image Storage (AWS S3) ---
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-2"
AWS_S3_BUCKET="footballeroo-images"

# --- Email Notifications (SendGrid) ---
SENDGRID_API_KEY=""
ADMIN_EMAIL=""

# --- Vercel (for CI/CD preview deploys) ---
# Only needed in GitHub Actions secrets
# VERCEL_TOKEN=""
# VERCEL_ORG_ID=""
# VERCEL_PROJECT_ID=""
