// ============================================================
// Footballeroo — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Users & Auth ---

enum UserRole {
  USER
  ADMIN
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  passwordHash       String?
  role               UserRole            @default(USER)
  image              String?
  dietary            DietaryRestriction[]
  favouriteTeams     String[]            @default([])
  cuisinePreferences String[]            @default([])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Relations
  addresses          Address[]
  orders             Order[]
  sessions           Session[]
  accounts           Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum DietaryRestriction {
  VEGAN
  VEGETARIAN
  PESCATARIAN
  HALAL
  KOSHER
  GLUTEN_FREE
  DAIRY_FREE
  NUT_FREE
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   // e.g. "Home", "Work"
  line1     String
  line2     String?
  city      String   @default("London")
  postcode  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// --- Football ---

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  country     String   @unique // ISO 3166-1 alpha-2
  cuisineTags String[] @default([])
  flagEmoji   String?

  homeFixtures Fixture[] @relation("HomeTeam")
  awayFixtures Fixture[] @relation("AwayTeam")

  @@map("teams")
}

model Fixture {
  id          String      @id @default(cuid())
  homeTeamId  String
  awayTeamId  String
  status      MatchStatus @default(SCHEDULED)
  homeScore   Int?
  awayScore   Int?
  kickoff     DateTime
  competition String      @default("FIFA World Cup 2026")
  venue       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  homeTeam Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])
  dishes   Dish[]

  @@map("fixtures")
}

// --- Dishes & Menu ---

enum MoodType {
  CELEBRATION
  COMFORT
  FUSION
  NEUTRAL
}

model Dish {
  id          String    @id @default(cuid())
  name        String
  description String    @db.Text
  ingredients Json      // Array of { name, quantity, unit, isOptional }
  recipe      String?   @db.Text
  cuisine     String
  mood        MoodType  @default(NEUTRAL)
  tags        String[]  @default([])
  prepTime    Int       // minutes
  price       Int       // pence
  imageUrl    String?
  tasteScore  Int       @default(0) // 0-100
  isActive    Boolean   @default(true)
  fixtureId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  fixture    Fixture?    @relation(fields: [fixtureId], references: [id])
  orderItems OrderItem[]

  @@index([fixtureId])
  @@index([cuisine])
  @@index([mood])
  @@index([isActive])
  @@map("dishes")
}

// --- Stock ---

enum StockStatus {
  SURPLUS
  ADEQUATE
  LOW
  OUT
}

enum StockUnit {
  KG
  LITRES
  UNITS
  PORTIONS
}

model StockItem {
  id            String      @id @default(cuid())
  ingredient    String      @unique
  quantity      Float
  unit          StockUnit
  threshold     Float       // low-stock alert level
  avgDailyUsage Float       @default(0)
  status        StockStatus @default(ADEQUATE)
  lastUpdated   DateTime    @default(now())
  createdAt     DateTime    @default(now())

  @@index([status])
  @@index([ingredient])
  @@map("stock_items")
}

// --- Orders ---

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
}

model Order {
  id                String      @id @default(cuid())
  userId            String
  status            OrderStatus @default(PENDING)
  totalPrice        Int         // pence
  deliveryFee       Int         @default(350) // pence
  deliveryAddressId String
  estimatedDelivery DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id])
  deliveryAddress Address     @relation(fields: [deliveryAddressId], references: [id])
  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  dishId         String
  dishName       String
  quantity       Int
  unitPrice      Int      // pence
  customisations String[] @default([])

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish  Dish  @relation(fields: [dishId], references: [id])

  @@map("order_items")
}
